PORT=5000

# ============================================
# MONGODB CONNECTION (REQUIRED)
# ============================================
# Get this from MongoDB Atlas:
# 1. Go to https://cloud.mongodb.com
# 2. Click "Database" → Click "Connect" on your cluster
# 3. Choose "Connect your application"
# 4. Copy the connection string
# 5. Replace <password> with your database user password
# 6. Add "/cloudliteracy" before the "?" 
#
# Example: mongodb+srv://cloudliteracy:YourPassword@cluster0.xxxxx.mongodb.net/cloudliteracy?retryWrites=true&w=majority
#
MONGODB_URI=PASTE_YOUR_MONGODB_CONNECTION_STRING_HERE

# ============================================
# JWT SECRET (REQUIRED)
# ============================================
# This is a random secret key for user authentication
# Generate one by running this command in terminal:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# Or just make up a long random string (32+ characters)
#
JWT_SECRET=PASTE_YOUR_RANDOM_SECRET_KEY_HERE

# ============================================
# STRIPE - Visa/Mastercard (REQUIRED FOR TESTING)
# ============================================
# Get these from Stripe Dashboard:
# 1. Go to https://dashboard.stripe.com/register
# 2. Sign up and log in
# 3. Go to Developers → API Keys
# 4. Copy both keys (they start with pk_test_ and sk_test_)
#
STRIPE_SECRET_KEY=PASTE_YOUR_STRIPE_SECRET_KEY_HERE
STRIPE_PUBLISHABLE_KEY=PASTE_YOUR_STRIPE_PUBLISHABLE_KEY_HERE

# ============================================
# PAYPAL (OPTIONAL)
# ============================================
# Get these from PayPal Developer:
# 1. Go to https://developer.paypal.com
# 2. Create an app in "My Apps & Credentials"
# 3. Copy Client ID and Secret
#
PAYPAL_CLIENT_ID=your_paypal_client_id
PAYPAL_CLIENT_SECRET=your_paypal_client_secret
PAYPAL_MODE=sandbox

# ============================================
# MTN MOBILE MONEY - Cameroon (OPTIONAL)
# ============================================
# Leave these as default for now
# Set up later when you get MTN approval
#
MTN_MOMO_API_KEY=your_mtn_api_key
MTN_MOMO_USER_ID=your_mtn_user_id
MTN_MOMO_SUBSCRIPTION_KEY=your_mtn_subscription_key
MTN_MOMO_BASE_URL=https://sandbox.momodeveloper.mtn.com

# ============================================
# ORANGE MONEY - Cameroon (OPTIONAL)
# ============================================
# Leave these as default for now
# Set up later when you get Orange merchant account
#
ORANGE_MONEY_API_KEY=your_orange_api_key
ORANGE_MONEY_MERCHANT_ID=your_orange_merchant_id
ORANGE_MONEY_BASE_URL=https://api.orange.com/orange-money-webpay

# ============================================
# FRONTEND URL
# ============================================
FRONTEND_URL=http://localhost:3000
