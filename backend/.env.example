PORT=5000

# ============================================
# MONGODB CONNECTION (REQUIRED)
# ============================================
# Get this from MongoDB Atlas:
# 1. Go to https://cloud.mongodb.com
# 2. Click "Database" → Click "Connect" on your cluster
# 3. Choose "Connect your application"
# 4. Copy the connection string
# 5. Replace <password> with your database user password
# 6. Add "/cloudliteracy" before the "?" 
#
# Example: mongodb+srv://cloudliteracy:YourPassword@cluster0.xxxxx.mongodb.net/cloudliteracy?retryWrites=true&w=majority
#
MONGODB_URI=PASTE_YOUR_MONGODB_CONNECTION_STRING_HERE

# ============================================
# JWT SECRET (REQUIRED)
# ============================================
# This is a random secret key for user authentication
# Generate one by running this command in terminal:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# Or just make up a long random string (32+ characters)
#
JWT_SECRET=PASTE_YOUR_RANDOM_SECRET_KEY_HERE

# ============================================
# STRIPE - Visa/Mastercard (REQUIRED FOR TESTING)
# ============================================
# Get these from Stripe Dashboard:
# 1. Go to https://dashboard.stripe.com/register
# 2. Sign up and log in
# 3. Go to Developers → API Keys
# 4. Copy both keys (they start with pk_test_ and sk_test_)
#
STRIPE_SECRET_KEY=PASTE_YOUR_STRIPE_SECRET_KEY_HERE
STRIPE_PUBLISHABLE_KEY=PASTE_YOUR_STRIPE_PUBLISHABLE_KEY_HERE

# ============================================
# PAYPAL (OPTIONAL)
# ============================================
# Get these from PayPal Developer:
# 1. Go to https://developer.paypal.com
# 2. Create an app in "My Apps & Credentials"
# 3. Copy Client ID and Secret
#
PAYPAL_CLIENT_ID=your_paypal_client_id
PAYPAL_CLIENT_SECRET=your_paypal_client_secret
PAYPAL_MODE=sandbox

# ============================================
# MTN MOBILE MONEY - Cameroon (PRODUCTION)
# ============================================
# Get these from MTN MoMo Developer Portal:
# 1. Register at https://momodeveloper.mtn.com
# 2. Subscribe to "Collection" product
# 3. Create API User and API Key in sandbox
# 4. For production, contact MTN for approval
#
# Sandbox URL: https://sandbox.momodeveloper.mtn.com
# Production URL: https://proxy.momoapi.mtn.com
#
MTN_MOMO_BASE_URL=https://sandbox.momodeveloper.mtn.com
MTN_MOMO_SUBSCRIPTION_KEY=your_collection_subscription_key
MTN_MOMO_API_USER=your_api_user_uuid
MTN_MOMO_API_KEY=your_api_key
MTN_MOMO_ENVIRONMENT=sandbox
MTN_MOMO_CURRENCY=EUR
MTN_MOMO_CALLBACK_URL=https://yourdomain.com/api/payments/mtn-callback

# For Cameroon Production:
# MTN_MOMO_ENVIRONMENT=production
# MTN_MOMO_CURRENCY=XAF
# MTN_MOMO_BASE_URL=https://proxy.momoapi.mtn.com

# ============================================
# ORANGE MONEY - Cameroon (PRODUCTION)
# ============================================
# Get these from Orange Developer Portal:
# 1. Contact Orange Cameroon business team
# 2. Request API merchant account
# 3. Requires business registration
# 4. Get OAuth2 credentials (Client ID & Secret)
#
# Sandbox URL: https://api.orange.com/orange-money-webpay/dev
# Production URL: https://api.orange.com/orange-money-webpay/cm
#
ORANGE_MONEY_BASE_URL=https://api.orange.com/orange-money-webpay/dev
ORANGE_MONEY_MERCHANT_ID=your_merchant_id
ORANGE_MONEY_MERCHANT_KEY=your_merchant_key
ORANGE_MONEY_CLIENT_ID=your_oauth_client_id
ORANGE_MONEY_CLIENT_SECRET=your_oauth_client_secret
ORANGE_MONEY_ENVIRONMENT=sandbox
ORANGE_MONEY_CURRENCY=XAF
ORANGE_MONEY_NOTIFY_URL=https://yourdomain.com/api/payments/orange-callback
ORANGE_MONEY_RETURN_URL=https://yourdomain.com/payment/success

# For Cameroon Production:
# ORANGE_MONEY_ENVIRONMENT=production
# ORANGE_MONEY_BASE_URL=https://api.orange.com/orange-money-webpay/cm

# ============================================
# FRONTEND URL
# ============================================
FRONTEND_URL=http://localhost:3000

# ============================================
# EMAIL CONFIGURATION (REQUIRED FOR PASSWORD RESET)
# ============================================
# Option 1: Gmail (Recommended for testing and small scale)
# Steps to get Gmail App Password:
# 1. Go to https://myaccount.google.com/security
# 2. Enable "2-Step Verification" if not already enabled
# 3. Go to https://myaccount.google.com/apppasswords
# 4. Select App: "Mail" and Device: "Other (Custom name)" - type "CloudLiteracy"
# 5. Click "Generate" and copy the 16-character password
# 6. Paste it below (remove spaces)
#
EMAIL_SERVICE=gmail
EMAIL_USER=your_email@gmail.com
EMAIL_PASSWORD=your_16_character_app_password (without spaces)
EMAIL_FROM=CloudLiteracy <your_email@gmail.com>

# Option 2: Custom SMTP (For production - SendGrid, AWS SES, Mailgun, etc.)
# Uncomment and configure if not using Gmail
# Remove or comment out the Gmail settings above if using custom SMTP
#
# EMAIL_SERVICE=smtp
# SMTP_HOST=smtp.sendgrid.net
# SMTP_PORT=587
# SMTP_SECURE=false
# SMTP_USER=apikey
# SMTP_PASSWORD=your_sendgrid_api_key
# EMAIL_FROM=CloudLiteracy <noreply@cloudliteracy.com>

# ============================================
# VOUCHER ENCRYPTION KEY (REQUIRED)
# ============================================
# Generate a random 64-character hex string:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
#
VOUCHER_ENCRYPTION_KEY=PASTE_YOUR_64_CHARACTER_HEX_STRING_HERE
